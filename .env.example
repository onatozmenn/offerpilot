# API
OFFERPILOT_HTTP_ADDR=127.0.0.1:8080

# PostgreSQL for host-based local development. These credentials are local placeholders only.
OFFERPILOT_DATABASE_URL=postgres://offerpilot:offerpilot_local@127.0.0.1:5432/offerpilot?sslmode=disable
OFFERPILOT_DATABASE_MAX_CONNS=10
OFFERPILOT_DATABASE_MIN_CONNS=1
OFFERPILOT_DATABASE_MAX_CONN_LIFETIME=30m
OFFERPILOT_DATABASE_MAX_CONN_IDLE_TIME=5m
OFFERPILOT_DATABASE_HEALTH_CHECK_PERIOD=30s
# Docker Compose overrides the URL where required and uses its service hostname.
# Container example: postgres://offerpilot:offerpilot_local@db:5432/offerpilot?sslmode=disable

# Docker Compose-only local substitutions. These are disposable development placeholders.
OFFERPILOT_POSTGRES_USER=offerpilot
OFFERPILOT_POSTGRES_PASSWORD=offerpilot_local
OFFERPILOT_POSTGRES_DATABASE=offerpilot
OFFERPILOT_POSTGRES_PORT=5432
OFFERPILOT_API_PORT=8080
OFFERPILOT_WEB_PORT=4173

# Logging
OFFERPILOT_LOG_LEVEL=info
OFFERPILOT_LOG_FORMAT=text

# Browser access
OFFERPILOT_CORS_ALLOWED_ORIGINS=http://localhost:5173

# HTTP safety limits
OFFERPILOT_HTTP_READ_HEADER_TIMEOUT=5s
OFFERPILOT_HTTP_READ_TIMEOUT=10s
OFFERPILOT_HTTP_WRITE_TIMEOUT=30s
OFFERPILOT_HTTP_IDLE_TIMEOUT=60s
OFFERPILOT_HTTP_MAX_BODY_BYTES=1048576
OFFERPILOT_SHUTDOWN_TIMEOUT=15s
OFFERPILOT_OUTCOME_MAX_FUTURE_SKEW=2m

# In-process simulation limits
OFFERPILOT_SIM_MAX_REQUESTS_PER_SECOND=100
OFFERPILOT_SIM_MAX_DECISIONS=100000
OFFERPILOT_SIM_MAX_WORKERS=32
OFFERPILOT_SIM_MAX_DURATION=30m
OFFERPILOT_SIM_MAX_ERRORS=100

# Frontend development. Vite proxies API calls to this target.
OFFERPILOT_API_PROXY_TARGET=http://127.0.0.1:8080
# Leave empty to use the browser's current origin.
VITE_API_BASE_URL=